{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Cloudflare Worker",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Debug: npm run dev",
      "configurations": ["Attach to Cloudflare Worker"],
      "preLaunchTask": "npm run dev",
      "stopAll": true
    }
  ]
}
