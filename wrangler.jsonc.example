{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "js-mvc",
  "main": "src/index.tsx",
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "vars": {
    "GITHUB_CLIENT_ID": "",
    "GITHUB_CLIENT_SECRET": ""
  },
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "replace-with-your-kv-id"
    }
  ],
  "d1_databases": [
    {
      "binding": "tenet_db",
      "database_name": "tenet-db",
      "database_id": "replace-with-your-d1-id"
    }
  ]
}
