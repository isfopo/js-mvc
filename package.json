{
  "name": "js-mvc",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "deploy": "npm run build && wrangler deploy",
    "build": "npm run build:css && npm run build:client && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "build:css": "tsx scripts/build-css.ts",
    "build:client": "tsx scripts/build-client.ts",
    "seed": "wrangler d1 execute tenet-db --file=migrations/002_seed_data.sql --local",
    "seed:remote": "wrangler d1 execute tenet-db --file=migrations/002_seed_data.sql --remote"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@types/clean-css": "^4.2.11",
    "@types/node": "^25.6.0",
    "clean-css": "^5.3.3",
    "gray-matter": "^4.0.3",
    "node-sql-parser": "^5.4.0",
    "purgecss": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
