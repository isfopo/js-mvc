    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@types/clean-css": "^4.2.11",
    "@types/node": "^25.6.0",
    "clean-css": "^5.3.3",
    "purgecss": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^6.4.2",
    "wrangler": "^4.87.0"
  }
}
